<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <AlienRace.ThingDef_AlienRace ParentName="Human">
        <defName>DrekirRace</defName>
        <label>drekir</label>
        <description>A draconic being created by the Prejarngalmok for the Sivilao to be used as pack animals.</description>
        <alienRace>
            <graphicPaths>
                <body>
					<path>Blank/blank</path>
				</body>
				<head>
					<path>Blank/blank</path>
				</head>
            </graphicPaths>
            <generalSettings>
                <alienPartGenerator>
                    <headTypes Inherit="False">
                        <li>TQAR_Drek_Head</li>
                    </headTypes>
                    <bodyTypes Inherit="False">
                        <li>TQAR_Drek_Body</li>
                    </bodyTypes>
					<colorChannels>
	                    <li>
					    	<name>skin</name>
						    <first Class="ColorGenerator_Options">	
    							<options>
		    						<li>
										<weight>8</weight>
										<only>RGBA(0.8,0.71,0.64,1.0)</only>
									</li>
			    					<li>
					    				<weight>8</weight>
					    				<only>RGBA(0.71,0.8,0.64,1.0)</only>
									</li>
		    						<li>
			    						<weight>8</weight>
					    				<only>RGBA(0.64,0.71,0.8,1.0)</only>
									</li>
		    						<li>
			    						<weight>8</weight>
				    					<only>RGBA(0.8,0.64,0.71,1.0)</only>
		    						</li>
    							</options>
							</first>
						</li>
					</colorChannels>
					<bodyAddons>
						<li>
							<name>eyes</name>
							<userCustomizable>true</userCustomizable>
							<colorChannel>eye</colorChannel>
							<inFrontOfBody>true</inFrontOfBody>
							<scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
							<defaultOffset>Center</defaultOffset>
							<alignWithHead>true</alignWithHead>
							<conditions>
								<BodyPart>
									<bodyPart>Head</bodyPart>
								</BodyPart>
								<RotStage>Fresh,Rotting</RotStage>
								<Posture>
									<drawnStanding>true</drawnStanding>
									<drawnLaying>true</drawnLaying>
								</Posture>
							</conditions>
							<extendedGraphics>
								<HeadType For="TQAR_Drek_Head">Blank/blank</HeadType>
							</extendedGraphics>
							<offsets>
								<south>
									<layerOffset>0</layerOffset>
								</south>
								<north/>
								<east>
									<layerOffset>0</layerOffset>
								</east>
							</offsets>
						</li>
						<li>
							<name>head</name>
							<userCustomizable>true</userCustomizable>
							<colorChannel>skin</colorChannel>
							<inFrontOfBody>true</inFrontOfBody>
							<scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
							<defaultOffset>Center</defaultOffset>
							<alignWithHead>true</alignWithHead>
							<conditions>
								<BodyPart>
									<bodyPart>Head</bodyPart>
								</BodyPart>
								<RotStage>Fresh,Rotting</RotStage>
								<Posture>
									<drawnStanding>true</drawnStanding>
									<drawnLaying>true</drawnLaying>
								</Posture>
							</conditions>
							<extendedGraphics>
								<HeadType For="TQAR_Drek_Head">Things/Pawn/Drekir/Parts/Heads/Drek_Head</HeadType>
							</extendedGraphics>
							<offsets>
								<south>
									<layerOffset>0</layerOffset>
								</south>
								<north/>
								<east>
									<layerOffset>0</layerOffset>
								</east>
							</offsets>
						</li>
						<li>
							<name>body</name>
							<userCustomizable>true</userCustomizable>
							<colorChannel>skin</colorChannel>
							<scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
							<defaultOffset>Center</defaultOffset>
							<conditions>
								<BodyPart>
									<bodyPart>Torso</bodyPart>
								</BodyPart>
								<RotStage>Fresh,Rotting</RotStage>
								<Posture>
									<drawnStanding>true</drawnStanding>
									<drawnLaying>true</drawnLaying>
									<drawnInBed>true</drawnInBed>
								</Posture>
							</conditions>
							<extendedGraphics>
								<BodyType For="TQAR_Drek_Body">Things/Pawn/Drekir/Parts/Bodies/Drek_Body</BodyType>
							</extendedGraphics>
							<offsets>
								<south>
									<layerOffset>0</layerOffset>
								</south>
								<north/>
								<east>
									<layerOffset>0</layerOffset>
								</east>
							</offsets>
						</li>
					</bodyAddons>
                </alienPartGenerator>
            </generalSettings>
            <styleSettings></styleSettings>
            <thoughtSettings></thoughtSettings>
            <relationSettings></relationSettings>
            <raceRestriction></raceRestriction>
            <compatibility></compatibility>
			<styleSettings>
				<li>
					<key>HairDef</key>
					<value>
						<hasStyle>false</hasStyle>
					</value>
				</li>
				<li>
					<key>BeardDef</key>
					<value>
						<hasStyle>true</hasStyle>
						<styleTags>
							<li>alienNoStyle</li>
						</styleTags>
					</value>
				</li>
				<li>
					<key>TattooDef</key>
					<value>
						<hasStyle>true</hasStyle>
						<styleTags>
							<li>alienNoStyle</li>
						</styleTags>
					</value>
				</li>
			</styleSettings>
        </alienRace>
    </AlienRace.ThingDef_AlienRace>
</Defs>